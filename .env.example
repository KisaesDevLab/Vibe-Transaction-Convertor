# --- Core ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
SESSION_SECRET=change-me-min-32-bytes-long-XXXXXXXXXXXXXXXX
WEB_BASE_URL=http://localhost:5173

# --- Storage ---
DATA_DIR=./data
MAX_UPLOAD_MB=25
MAX_BATCH_SIZE=100

# --- Postgres ---
DATABASE_URL=postgres://vibetc:vibetc@localhost:5432/vibetc?schema=vibetc

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Local Ollama (text extraction + OCR/vision, all on-appliance) ---
# Everything runs through a locally-hosted Ollama serving Qwen models
# (ADR-023). Text-layer statements go to the OpenAI-compatible
# /v1/chat/completions; scanned statements are OCR'd + extracted in one call
# on the native /api/chat vision path. Page images are processed locally and
# never egress. Base URL: OLLAMA_BASE_URL wins, then LLM_GATEWAY_URL (legacy
# alias), then the default below. Operator-overridable from /admin/llm-provider.
OLLAMA_BASE_URL=http://localhost:11434
# Vision/OCR model tag for scanned statements + reading check payees. MUST be a
# multimodal model (the default below is the on-box OCR model). When unset it
# defaults to minicpm-v4.5:latest — never the text model. Pull it first:
#   ollama pull minicpm-v4.5:latest
OLLAMA_VISION_MODEL=minicpm-v4.5:latest
# Per-call vision/OCR timeout. A 200–300 DPI page through a large -VL model on
# CPU — or the model's first (cold) load — can take several minutes; raise this
# if you see "ollama vision POST … timed out". Default 300000 (5 min).
OLLAMA_VISION_TIMEOUT_MS=300000
# Hard output cap for the vision call (Ollama num_predict). Bounds JSON length
# so a big statement can't run the call past the timeout. Default 8192.
# OLLAMA_VISION_MAX_TOKENS=8192
# Keep the model resident between calls (no cold reload on the next request).
OLLAMA_KEEP_ALIVE=30m
# Optional: widen Ollama's context window for long statements.
# OLLAMA_NUM_CTX=8192
# Optional reasoning toggle for the vision model ('on'/'off'). Off by default —
# it doubles latency and a schema-constrained OCR pass rarely needs it.
# OLLAMA_VISION_THINK=off
# OCR rasterization (scanned statements → JPEG page images for the vision call).
# VIBETC_OCR_RASTER_DPI=200
# VIBETC_OCR_RASTER_JPEG_QUALITY=80
# OCR-error safety net: hold a statement for human review before export when
# any transaction's model-reported confidence is below this (0..1). The Golden
# Rule already gates on balances; this catches misreads that still tie. Set to
# 0 to disable. Default 0.7.
# VIBETC_REVIEW_CONFIDENCE_THRESHOLD=0.7
# Auto-read check payees off cancelled-check images (local Qwen-VL) after
# extraction, for any check-numbered row left without a payee. The manual
# "Resolve check payees" button works regardless. Set false to disable the
# automatic pass. Default true.
# VIBETC_CHECK_PAYEE_AUTO=true

# --- LLM provider selection (DB setting overrides this on first run) ---
# local  = Ollama only (default). anthropic = Claude (text extraction only).
# Also: local-first / anthropic-first for text-layer fallback. Scanned
# statements always OCR locally on Ollama regardless of this setting.
LLM_PROVIDER=local

# Local Ollama text model (OpenAI-compat /v1 path).
LLM_GATEWAY_URL=http://localhost:11434
LLM_MODEL_ID=qwen3.5:35b-a3b
LLM_TIMEOUT_MS=60000
LLM_MAX_PROMPT_TOKENS=24000
# Output-token ceiling. Caps BOTH providers when set. Leave UNSET to let each
# provider use its own default (local 6000, Anthropic 32000); tune the
# Anthropic ceiling from Admin → LLM provider → "Max output tokens".
# LLM_MAX_COMPLETION_TOKENS=
LLM_CACHE_TTL_HOURS=24
LLM_NO_REPAIR=false
LLM_DEBUG_PAYLOADS=false

# Anthropic provider (optional, text-only; fallback when no DB-stored key)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Worker / appliance ---
WORKER_INLINE=true
APPLIANCE_MODE=false
APPLIANCE_VERSION=

# --- Build / ops ---
BUILD_SHA=
VIBETC_FORCE_OCR=false
VIBETC_DESKEW=false
# BullMQ lock duration (job-orphan threshold). Worst-case CPU OCR on a
# large statement is ~20 min; default 30 min covers that with margin.
VIBETC_EXTRACTION_TIMEOUT_MS=1800000
AUDIT_RETENTION_DAYS=
