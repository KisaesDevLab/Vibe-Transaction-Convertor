# --- Core ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
SESSION_SECRET=change-me-min-32-bytes-long-XXXXXXXXXXXXXXXX
WEB_BASE_URL=http://localhost:5173

# --- Storage ---
DATA_DIR=./data
MAX_UPLOAD_MB=25
MAX_BATCH_SIZE=100

# --- Postgres ---
DATABASE_URL=postgres://vibetc:vibetc@localhost:5432/vibetc?schema=vibetc

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Vibe Shield (OCR via Claude vision, PII-redacted through the gateway) ---
# Scanned pages are OCR'd by Claude vision through the Shield gateway
# (Anthropic Messages API at /v1/messages). Shield masks PII in each page
# image before Claude sees it. OPTIONAL — defaults to the appliance/docker
# gateway address http://vibe-shield-gateway:8080; only override if your
# gateway lives elsewhere. You DO still need to set the key below.
# VIBE_SHIELD_URL=http://vibe-shield-gateway:8080
# The Shield tenant key (vs_live_...). Sent as Authorization: Bearer. Prefer
# setting this via /admin/engines so it's stored encrypted instead of in env.
# VIBE_SHIELD_API_KEY=vs_live_...
# 120s headroom for Claude vision per page + the Shield hop. Lower if fast.
VIBE_SHIELD_TIMEOUT_MS=120000
VIBE_SHIELD_CONCURRENCY=2
VIBE_SHIELD_CACHE_TTL_DAYS=7
# Claude model used for OCR transcription.
# VIBE_SHIELD_MODEL=claude-sonnet-4-6
# Per-page OCR prompt + output-token cap.
# VIBE_SHIELD_OCR_PROMPT=Transcribe this statement page to Markdown…
# VIBE_SHIELD_MAX_OCR_TOKENS=8000
# Shield's cpa-converter-output policy hard-rejects (HTTP 400) any
# /v1/messages whose max_tokens exceeds this ceiling — it does not clamp.
# Both the OCR and extraction clients clamp their request to this value
# when routed through the gateway (direct-to-Anthropic is uncapped). Raise
# only if you raise the policy ceiling on the Shield side. Default 8192.
# VIBE_SHIELD_MAX_TOKENS_CEILING=8192
# Liveness probe sub-path (only override behind a path-rewriting proxy).
# VIBE_SHIELD_HEALTH_PATH=/health
# Redaction policy. MUST be cpa-converter-output (reid.mode=none + the only
# policy that permits the export-time materialize call). Also used by the
# extraction LLM call so OCR + extraction tokens share one session vault.
# VIBE_SHIELD_POLICY=cpa-converter-output

# --- LLM provider selection (DB setting overrides this on first run) ---
LLM_PROVIDER=local

# Local gateway (required when LLM_PROVIDER=local)
LLM_GATEWAY_URL=http://localhost:11434
LLM_MODEL_ID=qwen3-8b
LLM_TIMEOUT_MS=60000
LLM_MAX_PROMPT_TOKENS=24000
# Output-token ceiling. Caps BOTH providers when set. The local Qwen
# gateway keeps a modest cap (its context window is small); the
# Anthropic/Shield extraction path needs far more — a multi-page
# statement's transaction list does not fit in 6000 and the model
# truncates mid-array, failing with "transactions: Required". Leave this
# UNSET to let each provider use its own default (local 6000, Anthropic
# 32000), and tune the Anthropic ceiling from Admin → LLM provider →
# "Max output tokens" (DB-backed, overrides this env).
# LLM_MAX_COMPLETION_TOKENS=
LLM_CACHE_TTL_HOURS=24
LLM_NO_REPAIR=false
LLM_DEBUG_PAYLOADS=false

# Anthropic provider (optional fallback when no DB-stored key)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Worker / appliance ---
WORKER_INLINE=true
APPLIANCE_MODE=false
APPLIANCE_VERSION=

# --- Build / ops ---
BUILD_SHA=
VIBETC_FORCE_OCR=false
VIBETC_DESKEW=false
# BullMQ lock duration (job-orphan threshold). Worst-case CPU OCR on a
# large statement is ~20 min; default 30 min covers that with margin.
VIBETC_EXTRACTION_TIMEOUT_MS=1800000
AUDIT_RETENTION_DAYS=
