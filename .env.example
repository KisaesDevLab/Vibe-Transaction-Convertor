# --- Core ---
NODE_ENV=development
PORT=4000
LOG_LEVEL=info
SESSION_SECRET=change-me-min-32-bytes-long-XXXXXXXXXXXXXXXX
WEB_BASE_URL=http://localhost:5173

# --- Storage ---
DATA_DIR=./data
MAX_UPLOAD_MB=25
MAX_BATCH_SIZE=100

# --- Postgres ---
DATABASE_URL=postgres://vibetc:vibetc@localhost:5432/vibetc?schema=vibetc

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- GLM-OCR (llama.cpp llama-server hosting GLM-OCR; OpenAI-compatible) ---
GLM_OCR_URL=http://localhost:8090
# 120s gives ~2x headroom over the published 40-60s CPU inference time per
# page. Lower to ~30000 if running on GPU.
GLM_OCR_TIMEOUT_MS=120000
GLM_OCR_CONCURRENCY=2
GLM_OCR_CACHE_TTL_DAYS=7
# Endpoint sub-paths — only override behind a path-rewriting proxy.
# GLM_OCR_OCR_PATH=/v1/chat/completions
# GLM_OCR_HEALTH_PATH=/health
# GLM_OCR_VERSION_PATH=/version
# OpenAI request fields. `prompt` chooses between Text Recognition: (default,
# general OCR) and Table Recognition: (forces structured markdown tables).
# GLM_OCR_MODEL=GLM-OCR
# GLM_OCR_PROMPT=Text Recognition:
# Bearer token. Required when the OCR server was started with OCR_API_KEY.
# Sent as Authorization: Bearer <key> on every request. Prefer setting this
# via /admin/engines so it's stored encrypted instead of sitting in env.
# GLM_OCR_API_KEY=

# --- LLM provider selection (DB setting overrides this on first run) ---
LLM_PROVIDER=local

# Local gateway (required when LLM_PROVIDER=local)
LLM_GATEWAY_URL=http://localhost:11434
LLM_MODEL_ID=qwen3-8b
LLM_TIMEOUT_MS=60000
LLM_MAX_PROMPT_TOKENS=24000
LLM_MAX_COMPLETION_TOKENS=6000
LLM_CACHE_TTL_HOURS=24
LLM_NO_REPAIR=false
LLM_DEBUG_PAYLOADS=false

# Anthropic provider (optional fallback when no DB-stored key)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Worker / appliance ---
WORKER_INLINE=true
APPLIANCE_MODE=false
APPLIANCE_VERSION=

# --- Build / ops ---
BUILD_SHA=
VIBETC_FORCE_OCR=false
VIBETC_DESKEW=false
# BullMQ lock duration (job-orphan threshold). Worst-case CPU OCR on a
# large statement is ~20 min; default 30 min covers that with margin.
VIBETC_EXTRACTION_TIMEOUT_MS=1800000
AUDIT_RETENTION_DAYS=
