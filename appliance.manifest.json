{
  "$schema": "https://vibe.local/schemas/appliance-manifest-v1.json",
  "name": "vibe-tx-converter",
  "displayName": "Vibe Transactions Converter",
  "version": "0.1.0",
  "ports": [
    {
      "internal": 4000,
      "name": "http"
    }
  ],
  "depends": ["postgres", "redis", "glm-ocr", "llm-gateway"],
  "env": [
    {
      "name": "DATABASE_URL",
      "from": "postgres.connection_url",
      "with": { "schema": "vibetc" }
    },
    { "name": "REDIS_URL", "from": "redis.connection_url" },
    { "name": "GLM_OCR_URL", "from": "glm-ocr.url" },
    { "name": "LLM_GATEWAY_URL", "from": "llm-gateway.url" },
    { "name": "SESSION_SECRET", "from": "appliance.shared_secret" }
  ],
  "caddy": {
    "host": "vibetc.{appliance.domain}",
    "upstream": "vibe-tx-converter:4000"
  },
  "license": "PolyForm-Internal-Use-1.0.0"
}
